f106ccd52.svg&quot;}" data-vue-on="{}" data-v-app=""><div data-v-e026b23b=""><!----></div></div> <div class="prism d-none-mobile-app"></div> <div id="improvedialog-popup" class="white-popup mfp-hide" data-controller="improvedialog" style="max-width: 580px;"><h3 class="text-center" style="margin: -20px -20px 25px; padding: 20px 20px 15px; background: rgb(236, 241, 249);">
    Thanks for your feedback!
  </h3> <div data-target="improvedialog.initial"><p class="lead">
      Want to help us improve? <span style="opacity: 0.5;">(optional)</span></p> <ul style="list-style-type: none; padding-left: 0px;"><li><i class="fas fa-arrow-right" style="margin-right: 5px;"></i>
        Contribute this image &amp; help us make remove.bg better
      </li> <li><i class="fas fa-arrow-right" style="margin-right: 5px;"></i>
